# Admin Authentication
ADMIN_USERNAME=admin
# Generate password hash using: node -e "const bcrypt = require('bcrypt'); bcrypt.hash('your-password', 10).then(hash => console.log(hash))"
ADMIN_PASSWORD_HASH=$2b$10$...

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-this-in-production
JWT_EXPIRES_IN=24h

# Webhook Configuration (for new request notifications)
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-webhook-endpoint.com/webhook
WEBHOOK_SECRET=your-webhook-secret-optional

# Discord OAuth2 (for request submission authentication)
# Get these from Discord Developer Portal: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=https://your-domain.com/api/auth/discord/callback
