# Admin Authentication
ADMIN_USERNAME=admin
# Generate password hash using: node -e "const bcrypt = require('bcrypt'); bcrypt.hash('your-password', 10).then(hash => console.log(hash))"
#
# IMPORTANT: bcrypt hashes contain literal "$" characters. When this file is
# loaded via docker-compose `env_file:`, NO interpolation happens — the value
# must be the raw hash with single "$" characters (e.g. $2b$10$...).
# Do NOT escape as $$2b$$10$$... — that string is NOT a valid bcrypt hash and
# admin login will fail.
ADMIN_PASSWORD_HASH=$2b$10$replace-me-with-real-bcrypt-hash-from-the-command-above

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-this-in-production
JWT_EXPIRES_IN=24h

# Webhook Configuration (for new request notifications)
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-webhook-endpoint.com/webhook
WEBHOOK_SECRET=your-webhook-secret-optional

# Discord OAuth2 (for request submission authentication)
# Get these from Discord Developer Portal: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=https://your-domain.com/api/auth/discord/callback


# Discord channel webhook for "new content" notifications.
# Create one in Discord: Channel Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL.
# Leave unset / empty to disable notifications.
# Treat this URL as a secret -- anyone with it can post to that channel.
DISCORD_WEBHOOK_URL=
